DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# Embedding mode: "local" = lightweight local model, "api" = Embedding API
EMBED_MODE=local
EMBED_API_MODEL=deepseek-embedding
EMBED_LOCAL_MODEL=BAAI/bge-small-zh-v1.5

# Qdrant — use one of the two modes:
#   Remote (Docker):  set QDRANT_URL and leave QDRANT_LOCAL_PATH empty
#   Embedded (no Docker): set QDRANT_LOCAL_PATH and leave QDRANT_URL empty
QDRANT_URL=
QDRANT_LOCAL_PATH=./data/qdrant
QDRANT_COLLECTION=rag_knowledge_base

CHUNK_SIZE=1024
CHUNK_OVERLAP=64
TOP_K=5

UPLOAD_DIR=./data/uploads
MIN_SCORE=0.15
RECALL_TOP_K=100
RERANK_TOP_K=5
API_RETRY_TIMES=3

# HuggingFace mirror for China users
HF_ENDPOINT=https://hf-mirror.com
# fastembed model cache (keep out of system TEMP to avoid cleanup)
FASTEMBED_CACHE_PATH=./data/fastembed_cache
